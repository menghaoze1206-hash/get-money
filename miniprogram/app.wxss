page {
  --bg: #f5f6fa;
  --card: #ffffff;
  --text: #1a1a2e;
  --muted: #8e8e93;
  --green: #34c759;
  --red: #ff3b30;
  --orange: #ff9500;
  --blue: #007aff;
  --gold: #d4a853;
  --line: #e5e5ea;

  background: var(--bg);
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", sans-serif;
  color: var(--text);
  font-size: 28rpx;
}
