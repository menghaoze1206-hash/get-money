<view class="page">
  <view class="header">
    <view class="header-tag">中证红利 · 000922</view>
    <view class="header-title">红利基金投资信号</view>
    <view class="header-sub">基于股息率与国债收益率对比</view>
  </view>

  <view class="signal-card {{signal}}">
    <view class="signal-text">{{signalText}}</view>
    <view class="signal-desc">{{signalDesc}}</view>
  </view>

  <view class="metrics">
    <view class="metric-row">
      <view class="metric">
        <view class="metric-label">当前股息率</view>
        <view class="metric-value">{{currentYield}}%</view>
      </view>
      <view class="metric">
        <view class="metric-label">国债收益率(10Y)</view>
        <view class="metric-value">{{bondYield}}%</view>
      </view>
    </view>
    <view class="metric-divider"></view>
    <view class="metric-row">
      <view class="metric">
        <view class="metric-label">风险溢价</view>
        <view class="metric-value accent">{{riskPremium}}%</view>
      </view>
      <view class="metric">
        <view class="metric-label">历史均值(1年)</view>
        <view class="metric-value muted">{{histAvgYield}}%</view>
      </view>
    </view>
  </view>

  <view class="verdict">
    <view class="verdict-title">投策参考</view>
    <view class="verdict-text">{{verdictText}}</view>
  </view>

  <view class="footer">
    <view class="footer-text">数据来源：东方财富 · 中证指数</view>
    <view class="footer-text">更新时间：{{updateTime}}</view>
    <view class="footer-text warning">投资有风险，本页面仅供参考</view>
  </view>
</view>
